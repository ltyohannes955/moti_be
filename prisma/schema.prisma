generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ACTIVE
  INACTIVE
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

enum OrganizationType {
  PARTNER
  CLIENT
  VENDOR
}

enum CareerType {
  FULL_TIME
  PART_TIME
  CONTRACT
  REMOTE
}

enum ContactSubject {
  GENERAL_INQUIRY
  PRODUCT_QUOTE
  PARTNERSHIP
  TECHNICAL_SUPPORT
  CAREER_OPPORTUNITY
  COFFEE_EXPORT
  OTHER
}

enum ContactStatus {
  NEW
  READ
  RESPONDED
}

enum ApplicationStatus {
  NEW
  REVIEWED
  ACCEPTED
  REJECTED
}

enum BlogPostType {
  BLOG
  NEWS
}

enum ProcessingMethod {
  WASHED
  NATURAL
  HONEY
  SEMI_WASHED
  WET_HULLED
}

enum AcidityLevel {
  HIGH
  MEDIUM
  LOW
}

enum BodyLevel {
  FULL
  MEDIUM
  LIGHT
  LIGHT_TO_MEDIUM
  MEDIUM_TO_FULL
  DELICATE
  CREAMY
}

enum HarvestMonth {
  JANUARY
  FEBRUARY
  MARCH
  APRIL
  MAY
  JUNE
  JULY
  AUGUST
  SEPTEMBER
  OCTOBER
  NOVEMBER
  DECEMBER
}

enum CoffeeGradeStatus {
  AVAILABLE
  COMING_SOON
  UNAVAILABLE
}

enum TastingNote {
  JASMINE
  LEMON
  HONEY
  DARK_CHOCOLATE
  MILK_CHOCOLATE
  COCOA_POWDER
  CACAO_NIBS
  FUDGE
  BERGAMOT
  BLUEBERRY
  CARAMEL
  CINNAMON
  CITRUS
  COCOA
  EARTHY
  FLORAL
  FRUITY
  NUTTY
  SPICE
  STONE_FRUIT
  TEA
  TOBACCO
  VANILLA
  WINE
  ROASTED_NUTS
  APRICOT
  MOCHA
  BALANCED
  CLEAN
  TROPICAL_FRUIT
  BERRIES
  CHERRY
  PEACH
  PLUM
  ORANGE
  GRAPE
  LAVENDER
  ROSE
  MINT
  CEDAR
  SMOKY
  MALT
  MAPLE
  TOFFEE
  HAZELNUT
  WALNUT
  ALMOND
  BLACK_TEA
  GREEN_APPLE
  RAISIN
  SUGAR_CANE
  BLACK_PEPPER
  CLOVE
  NUTMEG
  GINGER
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(ADMIN)
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductCategory {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique
  description String?
  status      Status           @default(ACTIVE)
  categoryId  Int
  category    ProductCategory  @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}

model ProjectCategory {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Project {
  id          Int              @id @default(autoincrement())
  title       String
  slug        String           @unique
  description String?
  status      Status           @default(ACTIVE)
  categoryId  Int
  category    ProjectCategory  @relation(fields: [categoryId], references: [id])
  clientId    Int
  client      Organization     @relation(fields: [clientId], references: [id])
  images      ProjectImage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProjectImage {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}

model Organization {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique
  type        OrganizationType
  description String?
  website     String?
  logo        String?
  status      Status           @default(ACTIVE)
  projects    Project[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Department {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String       @unique
  description String?
  status      Status       @default(ACTIVE)
  teamMembers TeamMember[]
  careers     Career[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamMember {
  id           Int        @id @default(autoincrement())
  name         String
  position     String
  imageUrl     String?
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  bio          String?
  order        Int?
  status       Status     @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Career {
  id           Int           @id @default(autoincrement())
  title        String
  slug         String        @unique
  type         CareerType
  departmentId Int
  department   Department    @relation(fields: [departmentId], references: [id])
  description  String
  requirements String?
  location     String?
  salary       String?
  status       Status        @default(ACTIVE)
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Application {
  id          Int               @id @default(autoincrement())
  fullName    String
  email       String
  phoneNumber String?
  cvUrl       String
  coverLetter String?
  status      ApplicationStatus @default(NEW)
  careerId    Int
  career      Career            @relation(fields: [careerId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
}

model BlogPost {
  id         Int                 @id @default(autoincrement())
  title      String
  slug       String              @unique
  content    String
  excerpt    String?
  imageUrl   String?
  author     String?
  type       BlogPostType        @default(BLOG)
  status     Status              @default(ACTIVE)
  categories BlogPostCategory[]
  tags       BlogPostTag[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

model BlogCategory {
  id          Int                 @id @default(autoincrement())
  name        String
  slug        String              @unique
  description String?
  posts       BlogPostCategory[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model BlogTag {
  id        Int            @id @default(autoincrement())
  name      String
  slug      String         @unique
  posts     BlogPostTag[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model BlogPostCategory {
  blogPost   BlogPost     @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  blogPostId Int
  category   BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId Int

  @@id([blogPostId, categoryId])
}

model BlogPostTag {
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  blogPostId Int
  tag        BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId      Int

  @@id([blogPostId, tagId])
}

model CoffeeType {
  id            Int               @id @default(autoincrement())
  name          String
  slug          String            @unique
  origin        String
  grade         String
  description   String?
  imageUrl      String?
  altitude      String?
  processing    ProcessingMethod?
  acidity       AcidityLevel?
  body          BodyLevel?
  harvestSeason HarvestMonth[]
  tastingNotes  TastingNote[] @default([])
  badgeText     String?
  status        Status            @default(ACTIVE)
  grades        CoffeeTypeGrade[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model CoffeeGrade {
  id          Int               @id @default(autoincrement())
  grade       String
  qualityLevel String
  defects     String
  status      CoffeeGradeStatus @default(AVAILABLE)
  coffeeTypes CoffeeTypeGrade[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model CoffeeTypeGrade {
  coffeeTypeId  Int
  coffeeType    CoffeeType  @relation(fields: [coffeeTypeId], references: [id], onDelete: Cascade)
  coffeeGradeId Int
  coffeeGrade   CoffeeGrade @relation(fields: [coffeeGradeId], references: [id], onDelete: Cascade)

  @@id([coffeeTypeId, coffeeGradeId])
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  company   String
  message   String
  rating    Int
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id          Int            @id @default(autoincrement())
  fullName    String
  email       String
  subject     ContactSubject
  message     String
  phoneNumber String?
  companyName String?
  isRead      Boolean        @default(false)
  status      ContactStatus  @default(NEW)
  createdAt   DateTime       @default(now())
}

model GalleryCategory {
  id          Int            @id @default(autoincrement())
  name        String
  slug        String         @unique
  description String?
  images      GalleryImage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model GalleryImage {
  id          Int             @id @default(autoincrement())
  title       String
  slug        String          @unique
  imageUrl    String
  description String?
  status      Status          @default(ACTIVE)
  categoryId  Int
  category    GalleryCategory @relation(fields: [categoryId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Setting {
  id                 Int       @id @default(autoincrement())
  siteName           String    @default("")
  siteDescription    String    @default("")
  maintenanceMode    Boolean   @default(false)
  maintenanceMessage String    @default("")
  estimatedEndTime   DateTime?
  email              String    @default("")
  phone              String    @default("")
  address            String    @default("")
  facebook           String    @default("")
  linkedIn           String    @default("")
  twitter            String    @default("")
  instagram          String    @default("")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
